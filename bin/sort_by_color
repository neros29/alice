#!/bin/bash

SEARCH_PATH="${1:-.}"

fd -e jpg -e png -e webp -e jpeg -0 . "$SEARCH_PATH" |
    xargs -0 -P "$(nproc)" -I {} bash -c '
    stats=$(magick "{}" -colorspace HSL -format "%[fx:u.h] %[fx:u.s] %[fx:u.l]" info: 2>/dev/null)

    if [ -n "$stats" ]; then
        echo "$stats|{}"
    fi
' | awk -F'[ |]' '
{
    h = $1
    s = $2
    l = $3
    file = $4

    # Color group (0–7)
    group = int(h * 8)

    # Grayscale detection
    gray = (s < 0.1) ? 1 : 0

    print gray "|" group "|" l "|" s "|" file
}
' | sort -t'|' \
    -k1,1n \
    -k2,2n \
    -k3,3n \
    -k4,4nr |
    cut -d'|' -f5-
