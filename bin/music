#! python3
import os
import re
import argparse
import subprocess


def make_playlist():
    cwd = os.getcwd()
    match = re.match(r"Album -\s*(.*)", cwd.split("/")[-1])
    if match:
        name = match.group(1).strip()
    else:
        name = cwd.split("/")[-1].strip()
    data = []
    for path in os.listdir():
        if path.endswith((".mp3")):
            data.append(path)
    print(os.path.join(cwd, f"{name}.m3u"))
    if len(data) > 0:
        with open(f"{name}.m3u", "w") as f:
            f.write(f"# NAME: {name}\n")
            f.write("\n".join(data))
    else:
        print("No music files found")

def reload_music():
    subprocess.run(["/home/neros/Documents/projects/music/myenv/bin/python3", "/home/neros/Documents/projects/music/src/load.py"])


parser = argparse.ArgumentParser()
parser.add_argument("--gen")
args = parser.parse_args()

if args.gen:
    make_playlist()
else:
    reload_music()


