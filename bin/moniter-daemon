#!/bin/bash

# Path to your wallpaper script or awww commands
# You can expand this to include logic for different monitors
TARGET_LINK="$HOME/.config/omarchy/current/background"
handle_monitor_change() {
    # This runs whenever a monitor is added or removed
    # We use hyprctl monitors to see the current state

    # Example: Simply reload awww or run a specific command
    # You could add logic here to check WHICH monitor was added
    # by parsing 'hyprctl monitors'

    echo "Monitor change detected! Updating wallpapers..."

    # Add your awww commands here.
    # Example: awww wallpaper path/to/wallpaper.jpg
    # Or trigger a script that maps specific wallpapers to specific monitors
    #
    awww img "$TARGET_LINK" --transition-type wipe --transition-duration 2 --transition-fps 144
}

# The magic part: Listen to the Hyprland socket
# The socket location is stored in the $HYPRLAND_INSTANCE_SIGNATURE env var
socat -U - "UNIX-CONNECT:$XDG_RUNTIME_DIR/hypr/$HYPRLAND_INSTANCE_SIGNATURE/.socket2.sock" | while read -r line; do
    case "$line" in
    monitoradded*)
        handle_monitor_change
        ;;
    esac
done
